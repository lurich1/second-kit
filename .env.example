# Paystack (get keys from https://dashboard.paystack.com/#/settings/developer)
# Public key: safe for browser — use NEXT_PUBLIC_ prefix (inlined at build time)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional duplicate of the SAME pk_test_... value — read at runtime via /api/paystack/public-config
# so Vercel env changes work without redeploy. Do NOT use sk_ here.
# PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key: server only — never commit real values; never prefix with NEXT_PUBLIC_
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — SMS to kitchen (E.164)
# NEXT_PUBLIC_KITCHEN_SMS_NUMBER=+233536991464

# Optional — shown for MoMo manual payments
# NEXT_PUBLIC_PAYMENT_PHONE_DISPLAY=0536 991 464
